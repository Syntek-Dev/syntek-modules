# Lock Files: MUST be included in Docker for reproducible builds
# - uv.lock (Python)
# - Cargo.lock (Rust)
# - pnpm-lock.yaml (Node.js)
# DO NOT add lock files to .dockerignore!

# Environment files (NEVER include in Docker images)
.env
.env.*
!.env.*.example

# Secrets and credentials
*.pem
*.key
*.crt
*.p12
secrets/
credentials/

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.swp

# Logs
logs/
*.log

# Database files
*.db
*.sqlite
*.sqlite3

# Docker
docker-compose*.yml
Dockerfile*
.dockerignore

# Testing
.coverage
htmlcov/
.pytest_cache/
coverage/
test-results/

# Metrics data (keep structure, ignore data)
docs/METRICS/runs/*.json
docs/METRICS/feedback/*.json
docs/METRICS/aggregates/**/*.json
docs/METRICS/variants/*.json
docs/METRICS/optimisations/pending/*.json
docs/METRICS/optimisations/applied/*.json
docs/METRICS/optimisations/rejected/*.json

# Keep .gitkeep files for structure
!**/.gitkeep

# Claude configuration (optional - include for agent context)
# Uncomment to exclude:
# .claude/

# Build artifacts (include in final image)
!dist/
!build/
