# Staging Environment Variables
# Copy to .env.staging and customize

# Environment
ENVIRONMENT=staging
DEBUG=False

# Backend (Django)
DJANGO_SECRET_KEY=<generate-secure-key>
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=staging.syntek.com
DATABASE_URL=postgresql://<user>:<password>@staging-db.syntek.com:5432/syntek_modules_staging

# GraphQL
GRAPHQL_DEBUG=False
GRAPHQL_PLAYGROUND=True
GRAPHQL_INTROSPECTION=True

# PostgreSQL
POSTGRES_DB=syntek_modules_staging
POSTGRES_USER=<staging-user>
POSTGRES_PASSWORD=<generate-secure-password>
POSTGRES_HOST=staging-db.syntek.com
POSTGRES_PORT=5432

# Rust Encryption
RUST_ENCRYPTION_KEY=<generate-32-char-key>
RUST_LOG=info

# Cloudinary
CLOUDINARY_CLOUD_NAME=syntek-staging
CLOUDINARY_API_KEY=<staging-api-key>
CLOUDINARY_API_SECRET=<staging-api-secret>

# GlitchTip Logging
GLITCHTIP_DSN=https://<staging-key>@glitchtip.syntek.com/1
GLITCHTIP_ENVIRONMENT=staging
GLITCHTIP_TRACES_SAMPLE_RATE=1.0

# Web Frontend (Next.js)
NEXT_PUBLIC_API_URL=https://staging-api.syntek.com/graphql
NEXT_PUBLIC_ENVIRONMENT=staging
NODE_ENV=production

# Mobile Frontend (React Native)
EXPO_PUBLIC_API_URL=https://staging-api.syntek.com/graphql
EXPO_PUBLIC_ENVIRONMENT=staging

# Feature Flags
FEATURE_SUBSCRIPTIONS=true
FEATURE_AI_INTEGRATION=true
FEATURE_ANALYTICS=true

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000

# Performance
DATABASE_CONN_MAX_AGE=600
DATABASE_POOL_SIZE=20

# Docker
COMPOSE_PROJECT_NAME=syntek-modules-staging
