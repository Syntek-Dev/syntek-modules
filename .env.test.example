# Test Environment Variables
# Copy to .env.test and customize

# Environment
ENVIRONMENT=test
DEBUG=False

# Backend (Django)
DJANGO_SECRET_KEY=test-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
DATABASE_URL=postgresql://syntek_test:test_password@localhost:5432/syntek_modules_test

# GraphQL
GRAPHQL_DEBUG=False
GRAPHQL_PLAYGROUND=False

# PostgreSQL
POSTGRES_DB=syntek_modules_test
POSTGRES_USER=syntek_test
POSTGRES_PASSWORD=test_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Rust Encryption
RUST_ENCRYPTION_KEY=test-encryption-key-32-chars-long
RUST_LOG=warn

# Cloudinary (mocked in tests)
CLOUDINARY_CLOUD_NAME=syntek-test
CLOUDINARY_API_KEY=test-api-key
CLOUDINARY_API_SECRET=test-api-secret

# GlitchTip (disabled in tests)
GLITCHTIP_DSN=
GLITCHTIP_ENVIRONMENT=test

# Web Frontend
NEXT_PUBLIC_API_URL=http://testserver:8000/graphql
NEXT_PUBLIC_ENVIRONMENT=test
NODE_ENV=test

# Mobile Frontend
EXPO_PUBLIC_API_URL=http://testserver:8000/graphql
EXPO_PUBLIC_ENVIRONMENT=test

# Feature Flags (all enabled for testing)
FEATURE_SUBSCRIPTIONS=true
FEATURE_AI_INTEGRATION=true
FEATURE_ANALYTICS=true

# Testing
PYTEST_ADDOPTS=-v --tb=short --cov --cov-report=html
JEST_VERBOSE=true
CI=true

# Docker
COMPOSE_PROJECT_NAME=syntek-modules-test
