{
  "name": "@syntek/tokens",
  "version": "0.1.0",
  "private": true,
  "description": "Design token constants for all Syntek UI packages — colours, spacing, typography, and more",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./tokens.css",
    "./nativewind": {
      "types": "./dist/nativewind.d.ts",
      "import": "./dist/nativewind.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings 0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
