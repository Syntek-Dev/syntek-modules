# pnpm configuration for syntek-modules monorepo

# Use strict peer dependencies (prevent phantom dependencies)
strict-peer-dependencies=true

# Hoist all dependencies to root node_modules when possible
shamefully-hoist=false

# Use workspace protocol for internal dependencies
link-workspace-packages=true

# Save exact versions (no ^ or ~)
save-exact=true

# Automatically install peer dependencies
auto-install-peers=true

# Enable recursive installation
recursive-install=true

# Shared node_modules for all packages
shared-workspace-lockfile=true

# Node linker (hoisted is faster but isolated is safer)
node-linker=hoisted

# Resolution mode
resolution-mode=highest

# Build scripts configuration
# Note: esbuild build scripts are safe and required for TypeScript compilation
# The warning can be safely ignored or approved via: pnpm approve-builds

# Uncomment to auto-approve all build scripts (less secure):
# ignore-scripts=false
