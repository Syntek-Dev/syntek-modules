# Production Environment Variables
# NEVER commit this file with real values!
# Copy to .env.production and customize

# Environment
ENVIRONMENT=production
DEBUG=False

# Backend (Django)
DJANGO_SECRET_KEY=<generate-very-secure-key>
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.syntek.com
DATABASE_URL=postgresql://<user>:<password>@prod-db.syntek.com:5432/syntek_modules_prod

# GraphQL
GRAPHQL_DEBUG=False
GRAPHQL_PLAYGROUND=False
GRAPHQL_INTROSPECTION=False

# PostgreSQL
POSTGRES_DB=syntek_modules_prod
POSTGRES_USER=<prod-user>
POSTGRES_PASSWORD=<generate-very-secure-password>
POSTGRES_HOST=prod-db.syntek.com
POSTGRES_PORT=5432

# Rust Encryption
RUST_ENCRYPTION_KEY=<generate-very-secure-32-char-key>
RUST_LOG=warn

# Cloudinary
CLOUDINARY_CLOUD_NAME=syntek-prod
CLOUDINARY_API_KEY=<prod-api-key>
CLOUDINARY_API_SECRET=<prod-api-secret>

# GlitchTip Logging
GLITCHTIP_DSN=https://<prod-key>@glitchtip.syntek.com/2
GLITCHTIP_ENVIRONMENT=production
GLITCHTIP_TRACES_SAMPLE_RATE=0.1

# Web Frontend (Next.js)
NEXT_PUBLIC_API_URL=https://api.syntek.com/graphql
NEXT_PUBLIC_ENVIRONMENT=production
NODE_ENV=production

# Mobile Frontend (React Native)
EXPO_PUBLIC_API_URL=https://api.syntek.com/graphql
EXPO_PUBLIC_ENVIRONMENT=production

# Feature Flags
FEATURE_SUBSCRIPTIONS=true
FEATURE_AI_INTEGRATION=true
FEATURE_ANALYTICS=true

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# Performance
DATABASE_CONN_MAX_AGE=600
DATABASE_POOL_SIZE=50
REDIS_URL=redis://<redis-host>:6379/0

# Monitoring
PROMETHEUS_METRICS=True
METRICS_PORT=9090

# Backups
BACKUP_ENABLED=True
BACKUP_RETENTION_DAYS=30

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# Docker
COMPOSE_PROJECT_NAME=syntek-modules-prod
