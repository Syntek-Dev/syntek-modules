{
  "name": "syntek-modules",
  "version": "1.0.0",
  "description": "Modular repository containing reusable Django, React, React Native, and Rust modules",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.13.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "install:all": "pnpm install",
    "build": "pnpm -r --filter='./web/**' --filter='./mobile/**' --filter='./shared' build",
    "build:web": "pnpm -r --filter='./web/**' build",
    "build:mobile": "pnpm -r --filter='./mobile/**' build",
    "build:shared": "pnpm --filter='./shared' build",
    "dev": "pnpm -r --parallel --filter='./examples/**' dev",
    "test": "pnpm -r test",
    "test:web": "pnpm -r --filter='./web/**' test",
    "test:mobile": "pnpm -r --filter='./mobile/**' test",
    "test:shared": "pnpm --filter='./shared' test",
    "lint": "eslint . && pnpm -r lint",
    "lint:fix": "eslint . --fix && pnpm -r lint:fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "clean:build": "pnpm -r --parallel exec rm -rf dist build .next",
    "typecheck": "pnpm -r typecheck",
    "typecheck:python": "pyright",
    "version:check": "pnpm -r exec pnpm version --no-git-tag-version",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@eslint/js": "^9.20.0",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.0",
    "pyright": "^1.1.390",
    "typescript": "^5.9.0",
    "turbo": "^2.8.7"
  },
  "keywords": [
    "syntek",
    "modules",
    "monorepo",
    "django",
    "nextjs",
    "react",
    "react-native",
    "rust",
    "security",
    "authentication",
    "encryption"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/syntek/syntek-modules.git"
  },
  "author": "Syntek",
  "license": "MIT"
}
