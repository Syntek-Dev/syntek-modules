# Development Environment Variables
# Copy to .env.dev and customize

# Environment
ENVIRONMENT=development
DEBUG=True

# Backend (Django)
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://syntek_dev:dev_password@localhost:5432/syntek_modules_dev

# GraphQL
GRAPHQL_DEBUG=True
GRAPHQL_PLAYGROUND=True

# PostgreSQL
POSTGRES_DB=syntek_modules_dev
POSTGRES_USER=syntek_dev
POSTGRES_PASSWORD=dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Rust Encryption
RUST_ENCRYPTION_KEY=dev-encryption-key-32-characters-long
RUST_LOG=debug

# Cloudinary (for testing)
CLOUDINARY_CLOUD_NAME=syntek-dev
CLOUDINARY_API_KEY=your-dev-api-key
CLOUDINARY_API_SECRET=your-dev-api-secret

# GlitchTip Logging
GLITCHTIP_DSN=https://dev-key@glitchtip.syntek.com/1
GLITCHTIP_ENVIRONMENT=development

# Web Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000/graphql
NEXT_PUBLIC_ENVIRONMENT=development
NODE_ENV=development

# Mobile Frontend (React Native)
EXPO_PUBLIC_API_URL=http://localhost:8000/graphql
EXPO_PUBLIC_ENVIRONMENT=development

# Feature Flags (for testing)
FEATURE_SUBSCRIPTIONS=true
FEATURE_AI_INTEGRATION=true
FEATURE_ANALYTICS=true

# Testing
PYTEST_ADDOPTS=-v --tb=short
JEST_VERBOSE=true

# Docker (if using)
COMPOSE_PROJECT_NAME=syntek-modules-dev
