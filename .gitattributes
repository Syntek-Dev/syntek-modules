# Set default behavior to automatically normalize line endings
* text=auto

# Source code
*.py text eol=lf diff=python
*.rs text eol=lf diff=rust
*.js text eol=lf diff=javascript
*.jsx text eol=lf diff=javascript
*.ts text eol=lf diff=typescript
*.tsx text eol=lf diff=typescript
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Scripts
*.sh text eol=lf
*.bash text eol=lf

# Configuration
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.npmrc text eol=lf

# Documentation
*.txt text eol=lf
LICENSE text eol=lf
README text eol=lf
CHANGELOG text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.eot binary
*.woff binary
*.woff2 binary
*.pyc binary
*.db binary
*.sqlite binary
*.sqlite3 binary

# Exclude files from export
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore
.vscode export-ignore
.idea export-ignore
tests export-ignore
*.test.* export-ignore
*.spec.* export-ignore

